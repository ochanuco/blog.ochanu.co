{
  "name": "ochanuco-blog",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "wrangler deploy",
    "typecheck": "astro check",
    "import:hatena": "node scripts/import-hatena-posts.mjs",
    "seed:local": "npx emdash seed seed/seed.json --database ./data.db --on-conflict update",
    "refresh:hatena-local": "node scripts/import-hatena-posts.mjs && node scripts/reset-hatena-posts.mjs && npx emdash seed seed/seed.json --database ./data.db --on-conflict update && node scripts/sync-hatena-published-at.mjs --local",
    "sync:hatena-media": "node scripts/sync-hatena-media.mjs",
    "sync:hatena-published-at": "node scripts/sync-hatena-published-at.mjs",
    "sync:hatena-content-remote": "node scripts/sync-hatena-content-remote.mjs --remote",
    "refresh:hatena-production": "npm run refresh:hatena-local && node scripts/sync-hatena-media.mjs && node scripts/sync-hatena-content-remote.mjs --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.6",
    "@astrojs/react": "^5.0.0",
    "@emdash-cms/cloudflare": "^0.1.0",
    "@emdash-cms/plugin-forms": "^0.1.0",
    "@emdash-cms/plugin-webhook-notifier": "^0.1.0",
    "astro": "^6.1.2",
    "emdash": "^0.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/node": "^10.0.4",
    "@cloudflare/workers-types": "^4.20260401.1",
    "better-sqlite3": "^12.8.0",
    "wrangler": "^4.79.0"
  },
  "emdash": {
    "label": "Blog",
    "seed": "seed/seed.json"
  }
}
